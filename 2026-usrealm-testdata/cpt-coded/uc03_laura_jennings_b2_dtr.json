              { "linkId": "tooth-number", "answer": [{ "valueInteger": 3 }] },
              {
                "linkId": "clinical-narrative",
                "answer": [{
                  "valueString": "Patient Laura Jennings presented June 3, 2026 with increasing pain in upper right quadrant x 1 week. Clinical examination and periapical radiography confirm irreversible pulpitis on Tooth #3 (upper right first molar). Tooth non-responsive to cold reversal testing. Periapical radiographs reveal periapical changes consistent with pulpal necrosis. Significant decay present compromising coronal structure. Palliative emergency treatment (D9110) provided at initial visit. Root canal therapy (D3330) is clinically necessary to eliminate infection and preserve the tooth. Following successful obturation, a porcelain/ceramic crown (D2740) is required to restore full occlusal function and protect the endodontically treated tooth from fracture. Core buildup (D2393) requested contingent on assessment of remaining tooth structure at time of crown preparation."
                }]
              },
              { "linkId": "pulp-vitality", "answer": [{ "valueCoding": { "code": "irreversible-pulpitis", "display": "Irreversible pulpitis" } }] }
            ]
          },
          {
            "linkId": "radiographic-evidence",
            "item": [
              { "linkId": "xray-attached", "answer": [{ "valueBoolean": true }] },
              {
                "linkId": "xray-findings",
                "answer": [{
                  "valueString": "Periapical radiographs (D0220 + D0230) taken June 3, 2026. Radiograph attachment reference: urn:uuid:documentreference-periapical-xray. Findings: Periapical radiolucency at apex of Tooth #3 consistent with pulpal pathology. Significant carious lesion involving mesial and occlusal surfaces. Existing restoration noted. No root resorption detected."
                }]
              }
            ]
          },
          {
            "linkId": "requested-services",
            "item": [
              { "linkId": "rct-requested", "answer": [{ "valueBoolean": true }] },
              { "linkId": "crown-requested", "answer": [{ "valueBoolean": true }] },
              { "linkId": "buildup-requested", "answer": [{ "valueBoolean": true }] },
              {
                "linkId": "buildup-justification",
                "answer": [{
                  "valueString": "Significant carious lesion with existing restoration compromises coronal structure. Insufficient tooth structure anticipated at time of crown preparation to support crown without buildup. D2393 requested as conditionally required; final determination to be made at crown preparation appointment with supporting clinical documentation."
                }]
              }
            ]
          }
        ]
